# Database (use cloud provider for production: Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT secret for session tokens
JWT_SECRET="your-secure-random-secret-here"

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
# Authorized JavaScript Origins:
#   http://localhost:3000
#   https://cyber-sathi-2.vercel.app
# Authorized Redirect URIs:
#   http://localhost:3000/api/auth/google/callback
#   https://cyber-sathi-2.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# App URL (http://localhost:3000 for local, https://cyber-sathi-2.vercel.app for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Groq API key for AI mentor (optional)
GROQ_API_KEY="your-groq-api-key"
